---
interface Props {
  code: string;
  lang?: string;
  label?: string;
}

const { code, lang = "python", label } = Astro.props;
const uid = Math.random().toString(36).slice(2, 10);
---

<div class="code-wrapper" id={uid}>
  {label && <div class="code-label" style="position:absolute;top:0;left:0;">{label}</div>}
  <pre><code class={`language-${lang}`}>{code.trim()}</code></pre>
  <button class="copy-btn" data-copy={code.trim()}>Copy</button>
</div>

<script>
  (() => {
    const wrapper = document.getElementById("{uid}");
    const btn = wrapper?.querySelector(".copy-btn");
    if (btn) {
      btn.addEventListener("click", () => {
        const code = (btn as HTMLElement).dataset.copy || "";
        navigator.clipboard.writeText(code).then(() => {
          btn.textContent = "Copied";
          setTimeout(() => {
            btn.textContent = "Copy";
          }, 1500);
        });
      });
    }
  })();
</script>
