---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getSiteConfig } from "../site-config";

const { version } = await getSiteConfig();
---

<BaseLayout title="Benchmarks" currentPath="/benchmarks">
  <div class="page-header">
    <div class="container">
      <h1>Benchmarks</h1>
      <p>
        Benchmarked against equivalent C++ (g++ -O2) and Python 3.14. Best of 3 runs.
      </p>
    </div>
  </div>

  <div class="section" style="padding-top:var(--s-8);">
    <div class="container">

      <div class="callout" style="margin-bottom:var(--s-8);">
        <p style="font-size:var(--fs-sm);">
          <strong>Visuall matches or beats C++ on 6 of 10 macro benchmarks.</strong>
          Compute-bound integer and loop work is within 1.0&ndash;1.4&times; of C++.
          Recursion-heavy workloads (Ackermann, TreeSum) are 4&ndash;9&times; due to GC stack scanning overhead.
        </p>
      </div>

      <h2 style="margin-bottom:var(--s-4);">Macro Benchmarks</h2>

      <div style="overflow-x:auto;border:var(--border-width) solid var(--c-border);margin-bottom:var(--s-8);">
        <table style="border:none;">
          <thead>
            <tr>
              <th>Test</th>
              <th style="text-align:right;">C++ (ms)</th>
              <th style="text-align:right;">Visuall (ms)</th>
              <th style="text-align:right;">Python (ms)</th>
              <th style="text-align:right;">V / C++</th>
              <th style="text-align:right;">Py / C++</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Primes (trial div, 100K &times;3)</td>
              <td style="text-align:right;font-family:var(--font-mono);">23.2</td>
              <td style="text-align:right;font-family:var(--font-mono);">31.7</td>
              <td style="text-align:right;font-family:var(--font-mono);">415</td>
              <td style="text-align:right;font-family:var(--font-mono);">1.4&times;</td>
              <td style="text-align:right;font-family:var(--font-mono);">18&times;</td>
            </tr>
            <tr>
              <td>TreeSum (recursive, depth 22)</td>
              <td style="text-align:right;font-family:var(--font-mono);">15.2</td>
              <td style="text-align:right;font-family:var(--font-mono);">63.8</td>
              <td style="text-align:right;font-family:var(--font-mono);">1,298</td>
              <td style="text-align:right;font-family:var(--font-mono);">4.2&times;</td>
              <td style="text-align:right;font-family:var(--font-mono);">85&times;</td>
            </tr>
            <tr>
              <td>Collatz (1..100K)</td>
              <td style="text-align:right;font-family:var(--font-mono);">30.6</td>
              <td style="text-align:right;font-family:var(--font-mono);">23.1</td>
              <td style="text-align:right;font-family:var(--font-mono);">1,758</td>
              <td style="text-align:right;font-family:var(--font-mono);">0.8&times;</td>
              <td style="text-align:right;font-family:var(--font-mono);">57&times;</td>
            </tr>
            <tr>
              <td>Strings (200K f-strings)</td>
              <td style="text-align:right;font-family:var(--font-mono);">27.9</td>
              <td style="text-align:right;font-family:var(--font-mono);">47.9</td>
              <td style="text-align:right;font-family:var(--font-mono);">162</td>
              <td style="text-align:right;font-family:var(--font-mono);">1.7&times;</td>
              <td style="text-align:right;font-family:var(--font-mono);">6&times;</td>
            </tr>
            <tr>
              <td>Pi (Leibniz, 10M terms)</td>
              <td style="text-align:right;font-family:var(--font-mono);">23.1</td>
              <td style="text-align:right;font-family:var(--font-mono);">23.7</td>
              <td style="text-align:right;font-family:var(--font-mono);">2,884</td>
              <td style="text-align:right;font-family:var(--font-mono);">1.0&times;</td>
              <td style="text-align:right;font-family:var(--font-mono);">125&times;</td>
            </tr>
            <tr>
              <td>Nested loops (2000&times;2000)</td>
              <td style="text-align:right;font-family:var(--font-mono);">11.0</td>
              <td style="text-align:right;font-family:var(--font-mono);">10.7</td>
              <td style="text-align:right;font-family:var(--font-mono);">705</td>
              <td style="text-align:right;font-family:var(--font-mono);">1.0&times;</td>
              <td style="text-align:right;font-family:var(--font-mono);">64&times;</td>
            </tr>
            <tr>
              <td>Ackermann (3,11)</td>
              <td style="text-align:right;font-family:var(--font-mono);">178.8</td>
              <td style="text-align:right;font-family:var(--font-mono);">1,589.3</td>
              <td style="text-align:right;font-family:var(--font-mono);">28,098</td>
              <td style="text-align:right;font-family:var(--font-mono);">8.9&times;</td>
              <td style="text-align:right;font-family:var(--font-mono);">157&times;</td>
            </tr>
            <tr>
              <td>GCD sum (1..2000)</td>
              <td style="text-align:right;font-family:var(--font-mono);">56.2</td>
              <td style="text-align:right;font-family:var(--font-mono);">61.9</td>
              <td style="text-align:right;font-family:var(--font-mono);">724</td>
              <td style="text-align:right;font-family:var(--font-mono);">1.1&times;</td>
              <td style="text-align:right;font-family:var(--font-mono);">13&times;</td>
            </tr>
            <tr>
              <td>Fibonacci (fib(35) &times;500K)</td>
              <td style="text-align:right;font-family:var(--font-mono);">9.2</td>
              <td style="text-align:right;font-family:var(--font-mono);">9.7</td>
              <td style="text-align:right;font-family:var(--font-mono);">684</td>
              <td style="text-align:right;font-family:var(--font-mono);">1.0&times;</td>
              <td style="text-align:right;font-family:var(--font-mono);">74&times;</td>
            </tr>
            <tr>
              <td>Float distance (1M)</td>
              <td style="text-align:right;font-family:var(--font-mono);">10.4</td>
              <td style="text-align:right;font-family:var(--font-mono);">10.1</td>
              <td style="text-align:right;font-family:var(--font-mono);">403</td>
              <td style="text-align:right;font-family:var(--font-mono);">1.0&times;</td>
              <td style="text-align:right;font-family:var(--font-mono);">39&times;</td>
            </tr>
          </tbody>
        </table>
      </div>

      <h2 style="margin-bottom:var(--s-4);">Micro Benchmarks</h2>

      <div style="overflow-x:auto;border:var(--border-width) solid var(--c-border);margin-bottom:var(--s-8);">
        <table style="border:none;">
          <thead>
            <tr>
              <th>Test</th>
              <th>Iterations</th>
              <th style="text-align:right;">C++</th>
              <th style="text-align:right;">Visuall</th>
              <th style="text-align:right;">vs C++</th>
              <th style="text-align:right;">Python</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>Match dispatch</td>
              <td style="font-family:var(--font-mono);">1M</td>
              <td style="text-align:right;font-family:var(--font-mono);">11.9 ms</td>
              <td style="text-align:right;font-family:var(--font-mono);">9.2 ms</td>
              <td style="text-align:right;font-family:var(--font-mono);">0.8&times;</td>
              <td style="text-align:right;font-family:var(--font-mono);">222 ms</td>
            </tr>
            <tr>
              <td>Function call</td>
              <td style="font-family:var(--font-mono);">1M</td>
              <td style="text-align:right;font-family:var(--font-mono);">8.5 ms</td>
              <td style="text-align:right;font-family:var(--font-mono);">12.6 ms</td>
              <td style="text-align:right;font-family:var(--font-mono);">1.5&times;</td>
              <td style="text-align:right;font-family:var(--font-mono);">251 ms</td>
            </tr>
            <tr>
              <td>Tight loop sum</td>
              <td style="font-family:var(--font-mono);">100K</td>
              <td style="text-align:right;font-family:var(--font-mono);">7.1 ms</td>
              <td style="text-align:right;font-family:var(--font-mono);">7.7 ms</td>
              <td style="text-align:right;font-family:var(--font-mono);">1.1&times;</td>
              <td style="text-align:right;font-family:var(--font-mono);">47 ms</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div class="section-label">Methodology</div>
      <p style="font-size:var(--fs-sm);color:var(--c-text-secondary);">
        All tests run against equivalent C++ compiled with <code>g++ -O2</code> and Python 3.14.
        Best of 3 runs reported. Test machine: not documented; these are README benchmarks.
        Benchmarks updated for Visuall v{version}.
      </p>

    </div>
  </div>
</BaseLayout>
